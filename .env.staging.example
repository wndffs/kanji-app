# Public staging URLs used by local remote-smoke checks.
STAGING_WEB_URL=https://kanji-app.vercel.app
STAGING_API_URL=https://kanji-srs-api.onrender.com

# Vercel web build/runtime.
NEXT_PUBLIC_API_BASE_URL=https://kanji-srs-api.onrender.com

# Render API runtime. Set real secret values in the Render dashboard, not in git.
NODE_ENV=production
PORT=3001
WEB_ORIGIN=https://kanji-app.vercel.app
AUTH_MODE=local
AUTH_TOKEN_SECRET=<generate-with-node-crypto-randomBytes>
AUTH_SESSION_TTL_MINUTES=43200
DATABASE_URL=<neon-pooled-postgres-url>

# Optional until background jobs are implemented.
# REDIS_URL=<upstash-redis-url>

# Optional remote-smoke identity. If omitted, scripts/remote-smoke.mjs creates
# a unique throwaway user on every run.
STAGING_SMOKE_EMAIL=
STAGING_SMOKE_PASSWORD=
