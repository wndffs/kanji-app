{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmitOnError": true,
    "paths": {
      "@kanji-srs/content-importers": ["packages/content-importers/src/index.ts"],
      "@kanji-srs/db": ["packages/db/src/index.ts"],
      "@kanji-srs/japanese": ["packages/japanese/src/index.ts"],
      "@kanji-srs/shared": ["packages/shared/src/index.ts"],
      "@kanji-srs/srs": ["packages/srs/src/index.ts"],
      "@kanji-srs/ui": ["packages/ui/src/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  }
}
